{
  "name": "votechain-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=@votechain/frontend",
    "dev:backend": "npm run dev --workspace=@votechain/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
