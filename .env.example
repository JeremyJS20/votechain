# Environment
# Set to 'production' when deploying to Vercel
NODE_ENV=development

# Database (Supabase)
# Use Transaction Mode (port 6543) for Vercel functions
# Use Direct Mode (port 5432) for initial 'db push'
DATABASE_URL="postgres://[user].[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Didit Verification SDK
# Get these from your Didit Developer Dashboard
DIDIT_API_KEY=your_didit_api_key_here
DIDIT_WORKFLOW_ID=your_workflow_id_here
DIDIT_WEBHOOK_SECRET=your_webhook_secret_here

# Blockchain Configuration
# IMPORTANT: Use a strong, random string for production!
BLOCKCHAIN_SALT=your_random_salt_here

# CORS & Routing
FRONTEND_ORIGIN=http://localhost:5173
VITE_REST_API_URL=http://localhost:3001/api/v1

# Verification Services (Backend)
MOCK_VERIFICATION_URL=http://localhost:5174/mock-verification
DIDIT_CALLBACK_URL=http://localhost:5173/verification/biometric
DIDIT_API_URL=https://verification.didit.me/v3/session/

# Development Bypass
# Set to false before deploying to production!
BYPASS_BIOMETRIC_IN_DEV=true

# Crypto Parameters (RSA)
CRYPTO_ALGORITHM=RSASSA-PKCS1-v1_5
CRYPTO_MODULUS_LENGTH=2048
CRYPTO_HASH=SHA-256
VITE_CRYPTO_ALGORITHM=RSASSA-PKCS1-v1_5
VITE_CRYPTO_MODULUS_LENGTH=2048
VITE_CRYPTO_HASH=SHA-256
